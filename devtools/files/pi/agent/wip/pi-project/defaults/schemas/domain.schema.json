{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Domain Knowledge",
	"type": "object",
	"required": ["entries"],
	"properties": {
		"entries": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["id", "title", "content", "category"],
				"properties": {
					"id": { "type": "string" },
					"title": { "type": "string" },
					"content": { "type": "string", "description": "The knowledge, research finding, or reference material" },
					"category": { "type": "string", "enum": ["research", "reference", "domain-rule", "prior-art", "constraint"] },
					"source": { "type": "string", "description": "Where this knowledge came from" },
					"confidence": { "type": "string", "enum": ["high", "medium", "low"] },
					"related_requirements": {
						"type": "array",
						"items": { "type": "string" },
						"description": "IDs of requirements this informs"
					},
					"tags": { "type": "array", "items": { "type": "string" } }
				}
			}
		}
	}
}
