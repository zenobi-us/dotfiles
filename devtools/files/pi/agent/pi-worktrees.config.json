{
  "worktrees": {
    "**": {
      "worktreeRoot": "{{mainWorktree}}.worktrees",
      "onCreate": [
        "mise trust --yes",
        "mise setup",
        "zellij action new-tab --name {{name}}",
        "zellij action go-to-tab-name {{name}}",
        "zellij action new-pane --name pi --cwd {{path}}"
      ]
    }
  }
}
