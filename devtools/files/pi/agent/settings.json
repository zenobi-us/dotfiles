{
  "lastChangelogVersion": "0.80.2",
  "defaultThinkingLevel": "medium",
  "theme": "rose-pine-moon",
  "packages": [
    "npm:@marckrenn/pi-sub-bar",
    "npm:@marckrenn/pi-sub-core",
    "npm:pi-mermaid",
    "npm:pi-hashline-readmap",
    "npm:pi-llama-server",
    "npm:@tintinweb/pi-subagents",
    "./bundles/agent-core",
    "./bundles/developer",
    "./bundles/creator",
    "./bundles/researcher",
    "./bundles/business",
    "./bundles/platform",
    "./packages/pi-context-report",
    "./packages/pi-files",
    "./packages/pi-fzf",
    "./packages/pi-lsp",
    "./packages/pi-ask",
    "./packages/pi-tree",
    "./packages/pi-handoff",
    "./packages/pi-lazyskills",
    "./packages/pi-worktrunk",
    "./packages/pi-rose-pine"
  ],
  "shellCommandPrefix": "eval \"$(mise env -s bash)\"\nshopt -s expand_aliases\neval \"$(grep '^alias ' ~/.zshrc)\"",
  "hideThinkingBlock": true,
  "defaultProvider": "openai-codex",
  "enableSkillCommands": true,
  "quietStartup": true,
  "collapseChangelog": true,
  "autocompleteMaxVisible": 10,
  "enableInstallTelemetry": false,
  "doubleEscapeAction": "tree",
  "defaultModel": "gpt-5.5"
}
