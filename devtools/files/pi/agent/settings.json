{
  "lastChangelogVersion": "0.67.2",
  "defaultThinkingLevel": "medium",
  "theme": "rose-pine-moon",
  "packages": [
    "npm:@zenobius/pi-rose-pine",
    "npm:@marckrenn/pi-sub-bar",
    "npm:@marckrenn/pi-sub-core",
    "npm:pi-mermaid",
    "npm:pi-subagents",
    "npm:pi-hashline-readmap",
    "npm:pi-prompt-template-model",
    "npm:@ogulcancelik/pi-sketch",
    "./packages/agent-core",
    "./packages/developer",
    "./packages/creator",
    "./packages/researcher",
    "./packages/business",
    "./packages/platform"
  ],
  "shellCommandPrefix": "eval \"$(mise env -s bash)\"\nshopt -s expand_aliases\neval \"$(grep '^alias ' ~/.zshrc)\"",
