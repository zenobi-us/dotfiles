{
  "autocompleteMaxVisible": 10,
  "collapseChangelog": true,
  "defaultModel": "gpt-5.6-sol",
  "defaultProvider": "openai-codex",
  "defaultThinkingLevel": "high",
  "doubleEscapeAction": "tree",
  "enableInstallTelemetry": false,
  "enableSkillCommands": true,
  "hideThinkingBlock": true,
  "lastChangelogVersion": "0.80.6",
  "packages": [
    "npm:@marckrenn/pi-sub-core",
    "git:github.com/DietrichGebert/ponytail",
    "./bundles/agent-core",
    "./bundles/developer",
    "./bundles/matt-pocock",
    "./bundles/creator",
    "./bundles/researcher",
    "./bundles/business",
    "./bundles/platform",
    "./packages/pi-session-browser",
    "./packages/pi-fzf",
    "./packages/pi-lsp",
    "./packages/pi-tree",
    "./packages/pi-slopchop",
    "./packages/pi-autoresearch",
    "./packages/pi-ralph-wiggum",
    "./packages/pi-lazyskills",
    "./packages/pi-worktrunk",
    "./packages/pi-rose-pine",
    "./packages/pi-lmstudio-provider",
    "./packages/pi-agents-zellij",
    "./packages/pi-ask",
    "./packages/pi-annotate",
    "./packages/@vanillagreen/pi-background-tasks",
    "./packages/@vanillagreen/pi-caveman",
    "./packages/@vanillagreen/pi-codex-minimal-tools",
    "./packages/@vanillagreen/pi-extension-manager",
    "./packages/@vanillagreen/pi-hooks",
    "./packages/@vanillagreen/pi-output-policy",
    "./packages/@vanillagreen/pi-prompt-stash",
    "./packages/@vanillagreen/pi-qol",
    "./packages/@vanillagreen/pi-session-bridge",
    "./packages/@vanillagreen/pi-session-manager",
    "./packages/@vanillagreen/pi-skills-manager",
    "./packages/@vanillagreen/pi-task-panel",
    "./packages/@vanillagreen/pi-tool-renderer",
    "./packages/@vanillagreen/pi-web-tools"
  ],
  "quietStartup": true,
  "shellCommandPrefix": "eval \"$(mise env -s bash)\"\nshopt -s expand_aliases\neval \"$(grep '^alias ' ~/.zshrc)\"",
  "showHardwareCursor": false,
  "terminal": {
    "clearOnShrink": false,
    "showTerminalProgress": true
  },
  "theme": "rose-pine-moon",
  "transport": "sse",
  "vstack": {
    "extensionManager": {
      "disabledItems": [],
      "config": {
        "@vanillagreen/pi-qol": {
          "replaceFooter": false
        },
        "@vanillagreen/pi-caveman": {
          "mode": "full"
        }
      }
    }
  }
}
